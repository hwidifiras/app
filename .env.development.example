# Dev fork — copy to .env.development (never use for client VPS production)
# Next.js loads this automatically when you run: npm run dev

DATABASE_URL="file:./prisma/dev.db"
AUTH_SECRET="dev-only-secret-change-me-not-for-production"
APP_TIMEZONE="Africa/Tunis"
APP_URL="http://localhost:3000"
APP_NAME="GymDay"
# Laisser false : les comptes se créent dans Paramètres → Utilisateurs
ALLOW_PUBLIC_REGISTER="false"

# Resend — replace re_xxxxxxxxx with your key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
# Testing: use Resend sandbox sender; production: your verified domain
PASSWORD_RESET_FROM="GymDay <onboarding@resend.dev>"
