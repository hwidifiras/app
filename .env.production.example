# PostgreSQL is required for the multi-tenant SaaS app.
DATABASE_URL="postgresql://gymday:replace-with-strong-password@postgres:5432/gymday_prod?schema=public"

AUTH_SECRET="replace-with-a-long-random-secret"
APP_URL="https://your-domain.com"
APP_NAME="GymDay"
APP_TIMEZONE="Africa/Tunis"
SAAS_ROOT_DOMAIN="we-discipline.com"
DEFAULT_TENANT_SLUG="we-discipline"
ALLOW_PUBLIC_REGISTER="false"

# Host port mapped to the container. Use 3002 for the parallel SaaS staging stack.
HOST_PORT="3002"

# Resend - replace re_xxxxxxxxx with your key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
PASSWORD_RESET_FROM="GymDay <no-reply@your-domain.com>"
