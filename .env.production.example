# Postgres recommended for production (e.g. Neon). SQLite only for single-server demo.
DATABASE_URL="postgresql://user:password@host:5432/gymday?sslmode=require"

AUTH_SECRET="replace-with-a-long-random-secret"
APP_URL="https://your-domain.com"
APP_NAME="GymDay"
APP_TIMEZONE="Africa/Tunis"
ALLOW_PUBLIC_REGISTER="false"

# Resend — replace re_xxxxxxxxx with your key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
PASSWORD_RESET_FROM="GymDay <no-reply@your-domain.com>"
