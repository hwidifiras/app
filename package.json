{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run prisma:migrate:dev",
    "dev": "next dev",
    "dev:setup": "node scripts/dev-setup.mjs",
    "build": "next build",
    "start": "next start",
    "docker:dev:up": "node scripts/docker-compose.mjs -f docker-compose.dev.yml up -d --build",
    "docker:dev:down": "node scripts/docker-compose.mjs -f docker-compose.dev.yml down",
    "docker:prod:up": "node scripts/docker-compose.mjs up -d --build",
    "docker:prod:down": "node scripts/docker-compose.mjs down",
    "lint": "eslint",
    "pretest": "node scripts/test-db-reset.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "admin:create": "node scripts/create-admin.mjs",
    "admin:create:dev": "node scripts/with-dev-env.mjs scripts/create-admin.mjs",
    "email:test": "npx tsx scripts/test-resend.ts",
    "email:test:prod": "node scripts/test-resend-production.mjs",
    "permissions:backfill": "node scripts/backfill-user-permissions.mjs",
    "offers:backfill": "npx tsx scripts/backfill-offer-rules.ts",
    "offers:backfill:dev": "node scripts/with-dev-env.mjs scripts/run-offers-backfill.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:dev": "node scripts/with-dev-env.mjs scripts/run-prisma-migrate.mjs",
    "prisma:repair:dev": "node scripts/with-dev-env.mjs scripts/repair-club-settings-columns.mjs",
    "prisma:studio": "prisma studio",
    "handoff:check": "node scripts/handoff-check.mjs",
    "lighthouse": "node scripts/lighthouse-audit.mjs",
    "perf:check": "node scripts/perf-check.mjs",
    "perf:check:local": "node scripts/perf-check.mjs --with-server",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.1.0",
    "lucide-react": "0.468.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^4.8.0",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "lighthouse": "^12.8.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
