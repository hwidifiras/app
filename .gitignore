# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/reports/
/.local-audits/
/prisma/test.db
/prisma/test.db-journal
/prisma/dev.db
/prisma/dev.db-journal
/prisma/prod-local.db
/prisma/prod-local.db-journal
/prisma/prisma/

# uploaded club logos (keep directory via .gitkeep)
/public/branding/club-logo.*

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# SSH keys (never commit private keys)
key-gen-git
key-gen-git.pub
id_ed25519*
id_rsa*
*.ppk

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
next-dev*.log
next-start*.log
qa-artifacts/
/prisma/audit-build.db
/prisma/audit-build.db-journal

# env files (can opt-in for committing if needed)
.env*
!.env.production.example
!.env.development.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
